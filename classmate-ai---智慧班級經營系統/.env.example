# Google Gemini API Key (支援多組 Key，以逗號分隔)
GEMINI_API_KEY=your_key_1,your_key_2,your_key_3

# Groq API Key (備援 AI，當 Gemini 額度用盡時自動切換)
# 免費申請：https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# OpenRouter API Key (第三備援 AI，當 Gemini 和 Groq 都失敗時自動切換)
# 免費申請：https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
